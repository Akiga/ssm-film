<body>
    <!-- Success Message Modal -->
    <% if (successMessage) { %>
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                const myModal = new bootstrap.Modal(document.getElementById('exampleModalToggle'));
                myModal.show();
                document.querySelector(".text-success").style.display = "block";
            });
        </script>
    <% } %>

    <!-- Error Message Modal -->
    <% if (errorMessage) { %>
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                const myModal = new bootstrap.Modal(document.getElementById('exampleModalToggle2'));
                myModal.show();
                document.querySelector(".text-danger").style.display = "block";
            });
        </script>
    <% } %>


    <main class="manh-main">
        <!-- Slider Section -->
        <div class="manh-slider">
            <div id="carouselExampleAutoplaying" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img
                            rel="preload"
                            src="/img/hinh-nen-1920-1080-thumbnail.jpg"
                            class="d-block w-100 mobile-slider-img"
                            alt="Banner"
                            loading="eager"
                            fetchpriority="high"
                            width="1920"
                            height="700">
                    </div>

                    <div class="carousel-item">
                        <img
                            src="/img/hinh-nen-may-tinh-anime-4k (111).jpg"
                            class="d-block w-100 mobile-slider-img"
                            alt="Banner"
                            loading="lazy"
                            width="1920"
                            height="700">
                    </div>

                    <div class="carousel-item">
                        <img
                            src="/img/ironman_800x450.jpg"
                            class="d-block w-100 mobile-slider-img"
                            alt="Banner"
                            loading="lazy"
                            width="1920"
                            height="700">
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>

        <!-- Search Section -->
        <div class="mobile-search">
            <form class="d-flex" role="search" method="get" action="/search">
                <input class="form-control me-2" name="keyword" type="search" placeholder="Tìm kiếm" aria-label="Search">
                <button class="btn btn-outline-success" type="submit">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
            </form>
        </div>

        <!-- Main Content -->
        <div class="manh-content">
            <!-- Interest Categories Section -->
            <h2 class="manh-title">Bạn đang quan tâm gì?</h2>
            <div class="manh-topic">
                <!-- Navigation Dropdown -->
                <nav class="manh-nav-mobile">
                    <ul class="nav">
                        <!-- Country Dropdown -->
                        <li class="nav-item">
                            <div class="dropdown">
                                <button class="btn dropdown-toggle nav-link" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Quốc gia
                                </button>
                                <ul class="dropdown-menu">
                                    <% if (countries.length > 0) { %>
                                        <% countries.forEach(country => { %>
                                            <li>
                                                <a class="dropdown-item" href="/country/<%= country.slug %>">
                                                    <%= country.name %>
                                                </a>
                                            </li>
                                        <% }) %>
                                    <% } else { %>
                                        <p>Không có gì để hiển thị.</p>
                                    <% } %>
                                </ul>
                            </div>
                        </li>

                        <!-- Category Dropdown -->
                        <li class="nav-item">
                            <div class="dropdown">
                                <button class="btn dropdown-toggle nav-link" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Thể loại
                                </button>
                                <ul class="dropdown-menu">
                                    <% if (category.length > 0) { %>
                                        <% category.forEach(categoryItem => { %>
                                            <li>
                                                <a class="dropdown-item" href="/category/<%= categoryItem.slug %>">
                                                    <%= categoryItem.name %>
                                                </a>
                                            </li>
                                        <% }) %>
                                    <% } else { %>
                                        <p>Không có gì để hiển thị.</p>
                                    <% } %>
                                </ul>
                            </div>
                        </li>
                    </ul>
                </nav>

                <!-- Topic Cards -->
                <a href="/list/phim-le" class="card topic-card text-bg-primary holographic-card mb-3">
                    <div class="card-header">Chủ đề</div>
                    <div class="card-body">
                        <h5 class="card-title">Phim lẻ</h5>
                        <p class="manh-topic-text">Xem chủ đề <i class="fa-solid fa-forward"></i></p>
                    </div>
                </a>

                <a href="/list/phim-bo" class="card topic-card text-bg-success holographic-card mb-3">
                    <div class="card-header">Chủ đề</div>
                    <div class="card-body">
                        <h5 class="card-title">Phim bộ</h5>
                        <p class="manh-topic-text">Xem chủ đề <i class="fa-solid fa-forward"></i></p>
                    </div>
                </a>

                <a href="/list/hoat-hinh" class="card topic-card text-bg-warning holographic-card mb-3">
                    <div class="card-header">Chủ đề</div>
                    <div class="card-body">
                        <h5 class="card-title">Hoạt hình</h5>
                        <p class="manh-topic-text">Xem chủ đề <i class="fa-solid fa-forward"></i></p>
                    </div>
                </a>

                <a href="/list/tv-shows" class="card topic-card text-bg-dark holographic-card mb-3">
                    <div class="card-header">Chủ đề</div>
                    <div class="card-body">
                        <h5 class="card-title">TV Shows</h5>
                        <p class="manh-topic-text">Xem chủ đề <i class="fa-solid fa-forward"></i></p>
                    </div>
                </a>
            </div>


            <!-- Latest Movies Section -->
            <h2 class="manh-title">
                Phim mới cập nhật
                <a class="example_f" href="/list"><span><i class="fa-solid fa-forward"></i></span></a>
            </h2>
            <div class="manh-movie">
                <div class="container text-center">
                    <div class="row">
                        <div class="col manh-flex">
                            <% if (movies.items.length > 0) { %>
                                <% movies.items.forEach(movie => { %>
                                    <div class="card computer-card">
                                        <a href="/<%= movie.slug %>" class="card-inner">
                                            <div class="card-front">
                                                <img src="<%= movie.poster_url %>" class="movie-poster" alt="<%= movie.name %>">
                                            </div>
                                            <div class="card-back">
                                                <h5 class="card-title-back"><%= movie.name %></h5>
                                                <p class="card-text"><%= movie.origin_name %></p>
                                            </div>
                                        </a>
                                    </div>

                                    <a href="/<%= movie.slug %>" class="card mobile-card">
                                        <img src="<%= movie.poster_url %>" class="card-img-top mobile-card-img" alt="<%= movie.name %>">
                                        <h5 class="card-title mobile-title"><%= movie.name %></h5>
                                    </a>
                                <% }) %>
                            <% } else { %>
                                <p>Không có phim nào để hiển thị.</p>
                            <% } %>
                        </div>
                    </div>
                    <a href="/list" class="btn btn-outline-primary manh-mobile-list">Xem thêm</a>
                </div>
            </div>

            <!-- Single Movies Section -->
            <h2 class="manh-title">
                Top phim lẻ
                <a class="example_f" href="/list/phim-le"><span><i class="fa-solid fa-forward"></i></span></a>
            </h2>
            <div class="manh-movie">
                <div class="container text-center">
                    <div class="row">
                        <div class="col manh-flex">
                            <% if (phimLe.data.items.length > 0) { %>
                                <% phimLe.data.items.forEach(movie => { %>
                                    <div class="card computer-card">
                                        <a href="/<%= movie.slug %>" class="card-inner">
                                            <div class="card-front">
                                                <img src="https://phimimg.com/<%= movie.poster_url %>" class="movie-poster" alt="<%= movie.name %>">
                                            </div>
                                            <div class="card-back">
                                                <h5 class="card-title-back"><%= movie.name %></h5>
                                                <p class="card-text"><%= movie.origin_name %></p>
                                            </div>
                                        </a>
                                    </div>

                                    <a href="/<%= movie.slug %>" class="card mobile-card">
                                        <img src="https://phimimg.com/<%= movie.poster_url %>" class="card-img-top mobile-card-img" alt="<%= movie.name %>">
                                        <h5 class="card-title mobile-title"><%= movie.name %></h5>
                                    </a>
                                <% }) %>
                            <% } else { %>
                                <p>Không có phim nào để hiển thị.</p>
                            <% } %>
                        </div>
                    </div>
                    <a href="/list/phim-le" class="btn btn-outline-primary manh-mobile-list">Xem thêm</a>
                </div>
            </div>

            <!-- Series Section -->
            <h2 class="manh-title">
                Top phim bộ
                <a class="example_f" href="/list/phim-bo"><span><i class="fa-solid fa-forward"></i></span></a>
            </h2>
            <div class="manh-movie">
                <div class="container text-center">
                    <div class="row">
                        <div class="col manh-flex">
                            <% if (phimBo.data.items.length > 0) { %>
                                <% phimBo.data.items.forEach(movie => { %>
                                    <div class="card computer-card">
                                        <a href="/<%= movie.slug %>" class="card-inner">
                                            <div class="card-front">
                                                <img src="https://phimimg.com/<%= movie.poster_url %>" class="movie-poster" alt="<%= movie.name %>">
                                            </div>
                                            <div class="card-back">
                                                <h5 class="card-title-back"><%= movie.name %></h5>
                                                <p class="card-text"><%= movie.origin_name %></p>
                                            </div>
                                        </a>
                                    </div>

                                    <a href="/<%= movie.slug %>" class="card mobile-card">
                                        <img src="https://phimimg.com/<%= movie.poster_url %>" class="card-img-top mobile-card-img" alt="<%= movie.name %>">
                                        <h5 class="card-title mobile-title"><%= movie.name %></h5>
                                    </a>
                                <% }) %>
                            <% } else { %>
                                <p>Không có phim nào để hiển thị.</p>
                            <% } %>
                        </div>
                    </div>
                    <a href="/list/phim-bo" class="btn btn-outline-primary manh-mobile-list">Xem thêm</a>
                </div>
            </div>

            <!-- Anime Section -->
            <h2 class="manh-title">
                Anime siêu hot <i class="fa-solid fa-fire animate-fire"></i>
                <a class="example_f" href="/list/hoat-hinh"><span><i class="fa-solid fa-forward"></i></span></a>
            </h2>
            <div class="manh-movie">
                <div class="container text-center">
                    <div class="row">
                        <div class="col manh-flex">
                            <% if (hoatHinh.data.items.length > 0) { %>
                                <% hoatHinh.data.items.forEach(movie => { %>
                                    <div class="card computer-card">
                                        <a href="/<%= movie.slug %>" class="card-inner">
                                            <div class="card-front">
                                                <img src="https://phimimg.com/<%= movie.poster_url %>" class="movie-poster" alt="<%= movie.name %>">
                                            </div>
                                            <div class="card-back">
                                                <h5 class="card-title-back"><%= movie.name %></h5>
                                                <p class="card-text"><%= movie.origin_name %></p>
                                            </div>
                                        </a>
                                    </div>

                                    <a href="/<%= movie.slug %>" class="card mobile-card">
                                        <img src="https://phimimg.com/<%= movie.poster_url %>" class="card-img-top mobile-card-img" alt="<%= movie.name %>">
                                        <h5 class="card-title mobile-title"><%= movie.name %></h5>
                                    </a>
                                <% }) %>
                            <% } else { %>
                                <p>Không có phim nào để hiển thị.</p>
                            <% } %>
                        </div>
                    </div>
                    <a href="/list/hoat-hinh" class="btn btn-outline-primary manh-mobile-list">Xem thêm</a>
                </div>
            </div>

            <!-- TV Shows Section -->
            <h2 class="manh-title">
                TV shows được yêu thích nhất
                <a class="example_f" href="/list/tv-shows"><span><i class="fa-solid fa-forward"></i></span></a>
            </h2>
            <div class="manh-movie">
                <div class="container text-center">
                    <div class="row">
                        <div class="col manh-flex">
                            <% if (tvShows.data.items.length > 0) { %>
                                <% tvShows.data.items.forEach(movie => { %>
                                    <div class="card computer-card">
                                        <a href="/<%= movie.slug %>" class="card-inner">
                                            <div class="card-front">
                                                <img src="https://phimimg.com/<%= movie.poster_url %>" class="movie-poster" alt="<%= movie.name %>">
                                            </div>
                                            <div class="card-back">
                                                <h5 class="card-title-back"><%= movie.name %></h5>
                                                <p class="card-text"><%= movie.origin_name %></p>
                                            </div>
                                        </a>
                                    </div>

                                    <a href="/<%= movie.slug %>" class="card mobile-card">
                                        <img src="https://phimimg.com/<%= movie.poster_url %>" class="card-img-top mobile-card-img" alt="<%= movie.name %>">
                                        <h5 class="card-title mobile-title"><%= movie.name %></h5>
                                    </a>
                                <% }) %>
                            <% } else { %>
                                <p>Không có phim nào để hiển thị.</p>
                            <% } %>
                        </div>
                    </div>
                    <a href="/list/tv-shows" class="btn btn-outline-primary manh-mobile-list">Xem thêm</a>
                </div>
            </div>
        </div>
    </main>
</body>