<div class="manh-listFilm">
    <!-- Movies Grid Section -->
    <div class="manh-movie">
        <div class="container text-center">
            <div class="row">
                <div class="col manh-flex">
                    <% if (movies.items.length > 0) { %>
                        <% movies.items.forEach(movie => { %>
                            <!-- Desktop Card -->
                            <div class="card computer-card">
                                <a href="/<%= movie.slug %>" class="card-inner">
                                    <div class="card-front">
                                        <img src="<%= movie.poster_url %>" class="movie-poster" alt="<%= movie.name %>">
                                    </div>
                                    <div class="card-back">
                                        <h5 class="card-title-back"><%= movie.name %></h5>
                                        <p class="card-text"><%= movie.origin_name %></p>
                                    </div>
                                </a>
                            </div>

                            <!-- Mobile Card -->
                            <a href="/<%= movie.slug %>" class="card mobile-card">
                                <img src="<%= movie.poster_url %>" class="card-img-top mobile-card-img" alt="<%= movie.name %>">
                                <h5 class="card-title mobile-title"><%= movie.name %></h5>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <p class="no-movie-message">Không có phim nào để hiển thị.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Pagination Section -->
    <nav aria-label="Pagination">
        <ul class="pagination justify-content-center">
            <!-- Previous Button -->
            <% if (currentPage > 1) { %>
                <li class="page-item">
                    <a class="page-link" href="/list?page=<%= currentPage - 1 %>" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>
            <% } %>

            <!-- Page Info -->
            <li class="page-item disabled">
                <a class="page-link"><%= currentPage %> / <%= totalPage %></a>
            </li>

            <!-- Next Button -->
            <% if (currentPage < totalPage) { %>
                <li class="page-item">
                    <a class="page-link" href="/list?page=<%= currentPage + 1 %>" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            <% } %>
        </ul>
    </nav>
</div>